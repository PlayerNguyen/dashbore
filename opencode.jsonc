{
  "$schema": "https://opencode.ai/config.json",

  "lsp": true,

  "instructions": [
    "AGENTS.md",
    "docs/**/*.md"
  ],

  "watcher": {
    "ignore": [
      "node_modules/**",
      ".data/**",
      ".prisma/**",
      "@prisma/**",
      "packages/database/generated/**",
      "dist/**",
      ".git/**",
      "*.lock"
    ]
  },

  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  }
}
